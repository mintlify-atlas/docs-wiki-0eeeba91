  "keyFeatures": [
    "Modular monolith framework (AbpModule, DependsOn)",
    "Application bootstrap (AbpApplicationBase, ModuleLoader, ModuleManager)",
    "Dependency injection (ConventionalRegistrar, ExposeServices, ISingleton/Transient/ScopedDependency)",
    "Autofac integration (Volo.Abp.Autofac)",
    "Dynamic proxy + AOP aspects (Castle.Core)",
    "Domain-Driven Design building blocks (AggregateRoot, Entity, ValueObject, DomainService, Repository)",
    "Application Services layer (Volo.Abp.Ddd.Application)",
    "Unit of Work (Volo.Abp.Uow) and AbpUnitOfWorkMiddleware",
    "Repositories (IRepository, IReadOnlyRepository) over EFCore/MongoDB/MemoryDb/Dapper",
    "EntityFrameworkCore + per-provider packages (SqlServer, PostgreSql, MySQL, Oracle, Sqlite)",
    "MongoDB provider (Volo.Abp.MongoDB)",
    "Data filtering (IDataFilter, ISoftDelete, IMultiTenant)",
    "Data seeding (IDataSeedContributor)",
    "Multi-tenancy (CurrentTenant, ITenantStore, ITenantResolver, AbpMultiTenancyMiddleware)",
    "Authorization (Volo.Abp.Authorization, IPermissionDefinitionProvider, AbpAuthorizationPolicyProvider)",
    "Permission Management module (PermissionGrant, IPermissionStore)",
    "Feature Management module (FeatureDefinition, IFeatureStore)",
    "Setting Management module (ISettingProvider, ISettingStore)",
    "Tenant Management module",
    "Identity module (IdentityUser, IdentityRole, OrganizationUnit, IdentitySession, security log)",
    "Account module (login, register, profile, external logins)",
    "OpenIddict module + AspNetCore integration",
    "IdentityServer module (legacy)",
    "Audit Logging module (AuditLog, AuditingMiddleware, IAuditingHelper)",
    "Background Jobs (Volo.Abp.BackgroundJobs.* with default/Hangfire/Quartz/RabbitMQ providers)",
    "Background Workers (Volo.Abp.BackgroundWorkers, Hangfire and Quartz integrations)",
    "Event Bus (Local + Distributed) with RabbitMQ, Kafka, Azure ServiceBus, Dapr, Rebus transports",
    "Caching (Volo.Abp.Caching) with StackExchange.Redis distributed cache",
    "BLOB Storing (Volo.Abp.BlobStoring) with FileSystem/Memory/Azure/AWS/Google/Aliyun/Minio/Bunny providers and database-backed module",
    "Localization (Volo.Abp.Localization) and Multi-Lingual Objects",
    "Text Templating (Razor + Scriban)",
    "Validation (Volo.Abp.Validation + FluentValidation integration)",
    "Object Mapping (Volo.Abp.ObjectMapping + AutoMapper + Mapperly)",
    "Exception Handling and Business Exceptions",
    "Virtual File System (embedded resources for modules)",
    "AspNetCore.Mvc integration (AbpController, ApplicationServices as controllers, dynamic controllers)",
    "Auto API Controllers (ConventionalControllerRegistrar)",
    "AspNetCore.Mvc.UI (bundling, widgets, packages, themes)",
    "Blazor: Server, WebAssembly, MauiBlazor, theming, bundling",
    "BlazoriseUI integration",
    "MAUI client (Volo.Abp.Maui.Client)",
    "AspNetCore Authentication (JwtBearer, OAuth, OpenIdConnect)",
    "AspNetCore SignalR integration",
    "Serilog integration (Volo.Abp.AspNetCore.Serilog)",
    "Swashbuckle/Swagger integration",
    "HTTP Module + Http.Client + IdentityModel client",
    "RemoteServices abstractions",
    "Dapr integration (event bus, locking, http client, mvc)",
    "Dapper integration",
    "SignalR client simulation module",
    "CMS Kit (blogs, pages, comments, tags, ratings, menus, reactions, media descriptors)",
    "Blogging module",
    "Docs module (in-app docs viewer)",
    "Virtual File Explorer module",
    "Basic Theme module",
    "Users module (IUserData/User management abstractions)",
    "Client Simulation module",
    "ABP CLI (new, build, bundle, install-libs, generate-proxy, login, translate, switch-to-*)",
    "Project Building services in CLI",
    "Project Modification services (add-module, add-package)",
    "Service Proxying / proxy generation",
    "Solution templates (app, app-nolayers, module, console, maui, wpf)",
    "Angular UI packages (ng-packs/packages: core, components, identity, permission/feature/setting/tenant-management, theme-shared, theme-basic, account, oauth, generators, schematics)",
    "Angular resource packs (npm/packs: bootstrap, jquery, datatables, font-awesome, cms-kit, themes)",
    "Test infrastructure (Volo.Abp.TestBase, AspNetCore.TestBase, module-specific test projects)",
    "Sample apps and performance tests (test/AbpPerfTest, test/DistEvents)",
    "Imaging abstractions with ImageSharp, Magick.NET, SkiaSharp providers",
    "Emailing (Volo.Abp.Emailing + MailKit)",
    "SMS sending (abstractions + Aliyun + Tencent Cloud providers)",
    "JSON serialization (abstractions + System.Text.Json + Newtonsoft.Json)",
    "Distributed Locking (Volo.Abp.DistributedLocking + Dapr)",
    "AI abstractions (Volo.Abp.AI.* nascent)",
    "LDAP integration (Volo.Abp.Ldap)",
    "GDPR abstractions",
    "API Versioning abstractions",
    "Object Extending (extra properties on entities/DTOs)",
    "GUID generation (sequential GUIDs)",
    "Timing & TimeZone handling",
    "Specifications pattern",
    "Threading helpers (CancellationTokenProvider)",
    "Build scripts (build/build-all.ps1, test-all.ps1) and deploy scripts (deploy/*.ps1)"
  ],
